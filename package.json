    "preact": "^10.19.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0",
    "@preact/preset-vite": "^2.8.0",
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "workbox-window": "^7.0.0"
  }
