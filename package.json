{
  "name": "detetive-app",
  "version": "1.16.0",
  "description": "Terminal Noir Detective Study App",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:android": "npm run build && powershell -ExecutionPolicy Bypass -File build-android.ps1",
    "preview": "vite preview",
