    let archiveReviewState = null;
    let archiveAudioCtx = null;
    let archiveOsc = null;
    let archiveGain = null;
    let archiveFreqInterval = null;
    let archiveCurrentFreq = 'drone';
    let archiveSanity = 100;
    let archiveActive = false;
    let archiveForceUnlock = localStorage.getItem('noir_archive_force_unlock') === 'true';

    function isSecretTime() {
        if (archiveForceUnlock) return true;
        const h = new Date().getHours();
        return h >= 1 && h < 4;
    }

    function checkSecretTime() {
        const btn = document.getElementById('tab-btn-hidden-archive');
        if (!btn) return;
        if (isSecretTime()) {
            btn.classList.remove('hidden');
            if (!archiveActive) {
                archiveActive = true;
                document.getElementById('archive-scanlines').classList.add('active');
            }
            const remaining = (4 * 60) - (new Date().getHours() * 60 + new Date().getMinutes());
            const rt = document.getElementById('archive-time-remaining');
            if (rt) rt.textContent = `${Math.floor(remaining/60)}H${remaining%60}M RESTANTES`;
        } else {
            btn.classList.add('hidden');
            if (archiveActive) {
                archiveActive = false;
                document.getElementById('archive-scanlines').classList.remove('active');
                if (document.getElementById('tab-hidden-archive').classList.contains('block')) {
                    switchTab('tracker');
                }
            }
            if (archiveFreqInterval) { clearInterval(archiveFreqInterval); archiveFreqInterval = null; }
            if (archiveOsc) { try { archiveOsc.stop(); } catch(e) {} archiveOsc = null; }
            if (archiveMusicPlaying) archiveStopMusic();
        }
    }

    function switchArchiveTab(tabId) {
        ['forbidden', 'manuscript', 'dream', 'frequency'].forEach(id => {
            const panel = document.getElementById(`archive-panel-${id}`);
            if (panel) panel.classList.add('hidden');
            const btn = document.getElementById(`archive-tab-${id}`);
            if (btn) { btn.classList.remove('border-[#00ff41]', 'bg-[#00ff41]/10', 'text-[#00ff41]'); btn.classList.add('border-transparent', 'text-[#00ff41]/50'); }
        });
        const panel = document.getElementById(`archive-panel-${tabId}`);
        if (panel) panel.classList.remove('hidden');
        const btn = document.getElementById(`archive-tab-${tabId}`);
        if (btn) { btn.classList.remove('border-transparent', 'text-[#00ff41]/50'); btn.classList.add('border-[#00ff41]', 'bg-[#00ff41]/10', 'text-[#00ff41]'); }
        if (tabId === 'manuscript') archiveGenerateManuscript();
        if (tabId === 'dream') archiveGenerateDream();
    }

    // --- Arquivo Proibido (Review Mode) ---
    function archiveStartReview() {
        const available = [];
        subjects.forEach((sub, sidx) => {
            sub.topics.forEach((topic, tidx) => {
                if (topic.steps.rev || topic.steps.pre || topic.steps.teo || topic.steps.que) {
                    available.push({ sidx, tidx, name: topic.name, subject: sub.name });
                }
            });
        });
        if (available.length === 0) {
            document.getElementById('archive-review-empty').classList.remove('hidden');
            document.getElementById('archive-review-card').classList.add('hidden');
            document.getElementById('archive-review-result').classList.add('hidden');
            return;
        }
        document.getElementById('archive-review-empty').classList.add('hidden');
        document.getElementById('archive-review-result').classList.add('hidden');
        document.getElementById('btn-archive-start').classList.add('hidden');
        archiveSanity = 100;
        archiveReviewState = { items: available.sort(() => Math.random() - 0.5), idx: 0, correct: 0, wrong: 0 };
        archiveShowReviewCard();
    }

    function archiveShowReviewCard() {
        if (!archiveReviewState || archiveReviewState.idx >= archiveReviewState.items.length || archiveSanity <= 0) {
            archiveFinishReview();
            return;
        }
        const item = archiveReviewState.items[archiveReviewState.idx];
        document.getElementById('review-card-progress').textContent = `${archiveReviewState.idx + 1}/${archiveReviewState.items.length}`;
        document.getElementById('review-card-topic').textContent = `${item.subject} > ${item.name}`;
        document.getElementById('review-card-question').textContent = archiveGenerateQuestion(item);
        document.getElementById('review-card-answer').textContent = archiveGenerateAnswer(item);
        document.getElementById('review-card-back').classList.add('hidden');
        document.getElementById('review-card-actions').classList.add('hidden');
        document.getElementById('review-card-front').classList.remove('hidden');
        document.getElementById('archive-review-card').classList.remove('hidden');
        archiveUpdateSanity();
        setTimeout(() => {
            document.getElementById('review-card-back').classList.remove('hidden');
            document.getElementById('review-card-actions').classList.remove('hidden');
        }, 2000);
    }

    function archiveGenerateQuestion(item) {
        const qs = [
            `"O que contém o dossiê '${item.name}'?"`,
            `"Recite os conhecimentos do arquivo '${item.name}'."`,
            `"O abismo pergunta: qual o teor da ficha '${item.name}'?"`,
            `"Invoque as memórias do tópico '${item.name}'."`,
            `"As estrelas sussurram: revise '${item.name}'."`
        ];
        return qs[Math.floor(Math.random() * qs.length)];
    }

    function archiveGenerateAnswer(item) {
        const answers = [
            `Fragmento do saber: [${item.name}] arquivado em ${item.subject}. A verdade espera.`,
            `O tópico "${item.name}" reside no domínio de ${item.subject}. O cosmos confirma.`,
            `${item.name} — registrado em ${item.subject}. Que o conhecimento te fortaleça contra o caos.`,
            `A ficha "${item.name}" do dossiê ${item.subject} está na sua mente. Confie no abismo.`
        ];
        return answers[Math.floor(Math.random() * answers.length)];
    }

    function archiveReviewAnswer(remembered) {
        if (!archiveReviewState) return;
        if (remembered) {
            archiveReviewState.correct++;
            const frag = FORBIDDEN_FRAGMENTS[Math.floor(Math.random() * FORBIDDEN_FRAGMENTS.length)];
            document.getElementById('review-card-forbidden-fragment').textContent = frag;
            document.getElementById('review-card-actions').classList.add('hidden');
            setTimeout(() => {
                archiveReviewState.idx++;
                archiveShowReviewCard();
            }, 2500);
        } else {
            archiveReviewState.wrong++;
            archiveSanity = Math.max(0, archiveSanity - 15);
            archiveUpdateSanity();
            if (archiveSanity <= 0) {
                archiveFinishReview();
                return;
            }
            archiveReviewState.idx++;
            archiveShowReviewCard();
        }
    }

    function archiveUpdateSanity() {
        const pct = Math.max(0, archiveSanity);
        const bars = Math.floor(pct / 10);
        document.getElementById('archive-sanity-bar').textContent = '█'.repeat(bars) + '░'.repeat(Math.max(0, 10 - bars));
        document.getElementById('archive-sanity-pct').textContent = `${pct}%`;
        document.getElementById('archive-sanity-display').textContent = `SAN: ${pct}%`;
    }

    function archiveFinishReview() {
        document.getElementById('archive-review-card').classList.add('hidden');
        document.getElementById('archive-review-result').classList.remove('hidden');
        document.getElementById('btn-archive-start').classList.remove('hidden');
        const total = archiveReviewState ? archiveReviewState.correct + archiveReviewState.wrong : 0;
        if (archiveSanity <= 0) {
            document.getElementById('review-result-title').textContent = '☿ SANIDADE ESGOTADA';
            document.getElementById('review-result-detail').textContent = `O abismo consumiu sua mente. ${archiveReviewState ? archiveReviewState.correct : 0} fragmentos recuperados antes da queda.`;
            document.getElementById('review-result-fragment').textContent = '"Há um preço por todo conhecimento. Você pagou em sanidade."';
        } else {
            document.getElementById('review-result-title').textContent = archiveSanity > 50 ? '☿ REVISÃO COMPLETA' : '☿ REVISÃO INTERROMPIDA';
            document.getElementById('review-result-detail').textContent = `${archiveReviewState ? archiveReviewState.correct : 0}/${total} fragmentos decifrados. Sanidade restante: ${archiveSanity}%.`;
            const frag = FORBIDDEN_FRAGMENTS[Math.floor(Math.random() * FORBIDDEN_FRAGMENTS.length)];
            document.getElementById('review-result-fragment').textContent = frag;
        }
        archiveReviewState = null;
    }

    // --- Manuscrito Maldito ---
    function archiveGenerateManuscript() {
        document.getElementById('manuscript-loading').classList.remove('hidden');
        document.getElementById('manuscript-text').classList.add('hidden');
        setTimeout(() => {
            const totalTopics = subjects.reduce((sum, s) => sum + s.topics.length, 0);
            const totalHabits = habits.length;
            const totalStudyLogs = studyLogs.length;
            const totalPursuit = totalPursuitTime;
            const msgs = [
                `REGISTRO #${Math.floor(Math.random() * 9999)}: O agente ${agentName || 'desconhecido'} prossegue sua investiga��o. ${totalTopics} dossi�s abertos, ${totalStudyLogs} registros de tempo. O arquivo cresce. A noite testemunha.`,
                `FRAGMENTO ${new Date().toLocaleDateString('pt-PT')}: O cosmo observa seus h�bitos. ${totalHabits} rotinas registradas. ${Math.floor(totalPursuit / 60)} horas de persegui��o acumuladas. O abismo anota tudo.`,
                `DECRIPTOGRAFIA: A matr�cula do agente ecoa nos corredores do infinito. ${totalTopics} t�picos estudados. ${totalStudyLogs} sess�es conclu�das. O sil�ncio da madrugada guarda seus segredos.`,
                `CIFRA ${String.fromCharCode(65 + Math.floor(Math.random() * 26))}${Math.floor(Math.random() * 999)}: "${agentName || 'O INSPETOR'}" � este nome foi registrado no grande arquivo. ${totalTopics} dossi�s. ${totalHabits} protocolos. A insanidade � opcional.`,
                `TRANSMISS�O: Hor�rio ${new Date().getHours()}:${String(new Date().getMinutes()).padStart(2, '0')}. O arquivo oculto est� ativo. ${subjects.length} mat�rias em andamento. A n�voa c�smica envolve o pr�dio. Continue. O abismo precisa de voc�.`,
                `CODIFICA��O NECR�NOMA: ${agentName || 'O INSPETOR'} � ${totalTopics} fichas catalogadas. ${totalHabits} rituais di�rios registrados. O arquivo oculto pulsa. A madrugada � o v�u.`,
                `RECORDA��O C�SMICA: O agente ${agentName || 'desconhecido'} n�o � o primeiro a acessar este arquivo. ${totalTopics} t�picos � cada um uma vida passada. ${Math.floor(totalPursuit / 60)} horas de exist�ncia em loop.`,
                `SINAL DE BAUDELAIRE: ${new Date().toLocaleDateString('pt-PT')} � ${agentName || 'AN�NIMO'}. O sistema detectou ${totalStudyLogs} acessos. ${totalHabits} marcadores de sanidade. O grande arquivo se alimenta de sua dedica��o.`,
                `PROTOCOLO ${Math.floor(Math.random() * 9999)}: O sil�ncio entre ${new Date().getHours()}h e ${new Date().getHours() + 1}h cont�m ${totalTopics} frequ�ncias n�o humanas. O agente ${agentName || 'designado'} est� sendo monitorado pelo arquivo.`,
                `FRAGMENTO ${String.fromCharCode(65 + Math.floor(Math.random() * 26))}${String.fromCharCode(65 + Math.floor(Math.random() * 26))}-${Math.floor(Math.random() * 9999)}: "O que ${agentName || 'o agente'} estuda, o abisso aprende. O que o abisso aprende, nunca mais � esquecido." � ${totalTopics} t�picos assimilaram sua ess�ncia.`,
                `RELAT�RIO ${String.fromCharCode(65 + Math.floor(Math.random() * 26))}-${String(Math.floor(Math.random() * 999)).padStart(3, '0')}: ${totalStudyLogs} logs de tempo. ${Math.floor(totalPursuit)} minutos totais. ${agentName || 'O INSPETOR'} ultrapassou o limite recomendado de exposi��o ao conhecimento. O arquivo o acolhe.`,
                `CARTA DO ABISMO: "${agentName || 'CARO INSPETOR'}, sua persist�ncia � not�vel. ${totalTopics} t�picos dominados, ${totalHabits} h�bitos consolidados. O v�u entre mundos se desgasta a cada flashcard. Continue. O cosmos espera."`
            ];
            const msg = msgs[Math.floor(Math.random() * msgs.length)];
            document.getElementById('manuscript-loading').classList.add('hidden');
            const el = document.getElementById('manuscript-text');
            el.textContent = msg;
            el.classList.remove('hidden');
        }, 1500);
    }

    // --- Sonho Lúcido ---
    function archiveGenerateDream() {
        const el = document.getElementById('dream-vision-text');
        const sub = document.getElementById('dream-vision-sub');
        const template = COSMIC_DREAM_TEMPLATES[Math.floor(Math.random() * COSMIC_DREAM_TEMPLATES.length)];
        el.textContent = template.text;
        sub.textContent = template.sub + ' — ' + (agentName || 'INSPETOR');
        archiveDrawDreamCanvas();
    }

    function archiveDrawDreamCanvas() {
        const canvas = document.getElementById('dream-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        canvas.width = canvas.parentElement.offsetWidth;
        canvas.height = canvas.parentElement.offsetHeight;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = '#00ff4133';
        ctx.lineWidth = 1;
        const t = Date.now() / 1000;
        for (let i = 0; i < 50; i++) {
            const x = (canvas.width * 0.5) + Math.sin(t + i * 0.5) * (canvas.width * 0.3);
            const y = (canvas.height * 0.5) + Math.cos(t * 0.7 + i * 0.3) * (canvas.height * 0.3);
            ctx.beginPath();
            ctx.arc(x, y, 1 + Math.sin(t + i) * 2, 0, Math.PI * 2);
            ctx.stroke();
        }
        for (let i = 0; i < 10; i++) {
            const x = (canvas.width * 0.5) + Math.sin(t * 0.3 + i * 1.1) * (canvas.width * 0.4);
            const y = (canvas.height * 0.5) + Math.cos(t * 0.5 + i * 0.9) * (canvas.height * 0.35);
            ctx.beginPath();
            ctx.moveTo(x - 5, y);
            ctx.lineTo(x + 5, y);
            ctx.moveTo(x, y - 5);
            ctx.lineTo(x, y + 5);
            ctx.stroke();
        }
    }

    // --- Frequência do Abismo ---
    function archiveToggleFrequency() {
        const btn = document.getElementById('btn-frequency-toggle');
        if (archiveOsc) {
            if (archiveFreqInterval) { clearInterval(archiveFreqInterval); archiveFreqInterval = null; }
            try { archiveOsc.stop(); } catch(e) {}
            archiveOsc = null;
            btn.textContent = 'SINTONIZAR';
            return;
        }
        try {
            archiveAudioCtx = archiveAudioCtx || new (window.AudioContext || window.webkitAudioContext)();
            archiveOsc = archiveAudioCtx.createOscillator();
            archiveGain = archiveAudioCtx.createGain();
            archiveOsc.type = 'sawtooth';
            archiveOsc.frequency.value = archiveCurrentFreq === 'drone' ? 55 : archiveCurrentFreq === 'pulse' ? 110 : 220;
            archiveGain.gain.value = 0.08;
            archiveOsc.connect(archiveGain);
            archiveGain.connect(archiveAudioCtx.destination);
            archiveOsc.start();
            btn.textContent = 'DESSINTONIZAR';
            if (archiveCurrentFreq === 'pulse') {
                archiveFreqInterval = setInterval(() => {
                    if (archiveOsc) archiveOsc.frequency.value = 110 + Math.sin(Date.now() / 300) * 40;
                }, 50);
            } else if (archiveCurrentFreq === 'noise') {
                archiveFreqInterval = setInterval(() => {
                    if (archiveOsc) archiveOsc.frequency.value = 80 + Math.random() * 200;
                }, 100);
            }
            archiveDrawFrequency();
        } catch(e) { console.log('Audio do abismo indisponivel:', e); }
    }

    function archiveSetFreq(type) {
        archiveCurrentFreq = type;
        if (archiveOsc) {
            if (archiveFreqInterval) { clearInterval(archiveFreqInterval); archiveFreqInterval = null; }
            archiveOsc.frequency.value = type === 'drone' ? 55 : type === 'pulse' ? 110 : 220;
            if (type === 'pulse') {
                archiveFreqInterval = setInterval(() => {
                    if (archiveOsc) archiveOsc.frequency.value = 110 + Math.sin(Date.now() / 300) * 40;
                }, 50);
            } else if (type === 'noise') {
                archiveFreqInterval = setInterval(() => {
                    if (archiveOsc) archiveOsc.frequency.value = 80 + Math.random() * 200;
                }, 100);
            }
        }
        document.querySelectorAll('.archive-freq-btn').forEach(b => {
            b.classList.remove('border-[#00ff41]', 'text-[#00ff41]');
            b.classList.add('border-[#00ff41]/30', 'text-[#00ff41]/60');
        });
        const active = document.querySelector(`.archive-freq-btn[onclick*="${type}"]`);
        if (active) { active.classList.remove('border-[#00ff41]/30', 'text-[#00ff41]/60'); active.classList.add('border-[#00ff41]', 'text-[#00ff41]'); }
    }

    function archiveDrawFrequency() {
        const canvas = document.getElementById('frequency-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
        let x = 0;
        function draw() {
            if (!archiveOsc) { ctx.clearRect(0, 0, canvas.width, canvas.height); return; }
            ctx.fillStyle = 'rgba(0, 4, 8, 0.1)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.strokeStyle = '#00ff4144';
            ctx.lineWidth = 1;
            ctx.beginPath();
            for (let i = 0; i < canvas.width; i += 2) {
                const y = canvas.height / 2 + Math.sin((i + x) * 0.02 + Date.now() * 0.001) * (canvas.height / 4) + (Math.random() - 0.5) * 5;
                i === 0 ? ctx.moveTo(i, y) : ctx.lineTo(i, y);
            }
            ctx.stroke();
            ctx.strokeStyle = '#00ff4111';
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            for (let i = 0; i < canvas.width; i += 3) {
                const y = canvas.height / 2 + Math.cos((i + x) * 0.01 + Date.now() * 0.0007) * (canvas.height / 6);
                i === 0 ? ctx.moveTo(i, y) : ctx.lineTo(i, y);
            }
            ctx.stroke();
            x += 0.3;
            requestAnimationFrame(draw);
        }
        draw();
    }
    // --- Arquivo Oculto: Soundtrack Lovecraftiana ---
    let archiveMusicCtx = null;
    let archiveMusicNodes = [];
    let archiveMusicPlaying = false;
    let archiveMusicPrevState = { enabled: false, track: '', crossHidden: false };

    function archiveStartMusic() {
        if (archiveMusicPlaying) return;
        try {
            archiveMusicCtx = new (window.AudioContext || window.webkitAudioContext)();
            if (archiveMusicCtx.state === 'suspended') archiveMusicCtx.resume();
            const now = archiveMusicCtx.currentTime;
            const bgMusic = document.getElementById('bg-jazz-music');
            const cross = document.getElementById('music-cross-1');
            archiveMusicPrevState.enabled = musicEnabled;
            archiveMusicPrevState.track = currentTrackId;
            archiveMusicPrevState.crossHidden = cross ? cross.classList.contains('hidden') : true;
            if (musicEnabled) { if (bgMusic) bgMusic.pause(); stopDefconAmbience(); }
            if (enigmaAmbienceActive) {
                const btn = document.getElementById('btn-enigma-ambience');
                if (btn) btn.textContent = 'ATIVAR SALA';
                enigmaAmbienceActive = false; stopDefconAmbience();
            }
            const drone1 = archiveMusicCtx.createOscillator();
            const drone1Gain = archiveMusicCtx.createGain();
            drone1.type = 'sawtooth';
            drone1.frequency.setValueAtTime(33, now);
            drone1.frequency.linearRampToValueAtTime(35, now + 30);
            drone1Gain.gain.setValueAtTime(0.04, now);
            drone1Gain.gain.linearRampToValueAtTime(0.025, now + 30);
            drone1.connect(drone1Gain);
            drone1Gain.connect(archiveMusicCtx.destination);
            drone1.start(now);
            archiveMusicNodes.push(drone1, drone1Gain);
            const drone2 = archiveMusicCtx.createOscillator();
            const drone2Gain = archiveMusicCtx.createGain();
            drone2.type = 'sine';
            drone2.frequency.setValueAtTime(49.5, now);
            drone2.frequency.linearRampToValueAtTime(52, now + 45);
            drone2Gain.gain.setValueAtTime(0.02, now);
            drone2Gain.gain.linearRampToValueAtTime(0.035, now + 45);
            drone2.connect(drone2Gain);
            drone2Gain.connect(archiveMusicCtx.destination);
            drone2.start(now);
            archiveMusicNodes.push(drone2, drone2Gain);
            const sub = archiveMusicCtx.createOscillator();
            const subGain = archiveMusicCtx.createGain();
            sub.type = 'sine';
            sub.frequency.setValueAtTime(16, now);
            subGain.gain.setValueAtTime(0.06, now);
            subGain.gain.linearRampToValueAtTime(0.04, now + 60);
            sub.connect(subGain);
            subGain.connect(archiveMusicCtx.destination);
            sub.start(now);
            archiveMusicNodes.push(sub, subGain);
            function scheduleBell() {
                if (!archiveMusicPlaying) return;
                const bellTime = archiveMusicCtx.currentTime + 5 + Math.random() * 20;
                const bellFreqs = [177, 213, 277, 313, 355, 421, 533];
                const f = bellFreqs[Math.floor(Math.random() * bellFreqs.length)];
                const osc = archiveMusicCtx.createOscillator();
                const gain = archiveMusicCtx.createGain();
                osc.type = 'sine';
                osc.frequency.setValueAtTime(f, bellTime);
                gain.gain.setValueAtTime(0, bellTime);
                gain.gain.linearRampToValueAtTime(0.008, bellTime + 0.5);
                gain.gain.linearRampToValueAtTime(0.003, bellTime + 2);
                gain.gain.linearRampToValueAtTime(0, bellTime + 4);
                osc.connect(gain);
                gain.connect(archiveMusicCtx.destination);
                osc.start(bellTime);
                osc.stop(bellTime + 4);
                archiveMusicNodes.push(osc, gain);
                setTimeout(scheduleBell, 5000 + Math.random() * 20000);
            }
            setTimeout(scheduleBell, 8000);
            const noiseBuffer = archiveMusicCtx.createBuffer(1, archiveMusicCtx.sampleRate * 2, archiveMusicCtx.sampleRate);
            const noiseData = noiseBuffer.getChannelData(0);
            for (let i = 0; i < noiseBuffer.length; i++) noiseData[i] = (Math.random() * 2 - 1) * Math.pow(Math.random(), 3);
            const noiseSource = archiveMusicCtx.createBufferSource();
            noiseSource.buffer = noiseBuffer;
            noiseSource.loop = true;
            const noiseFilter = archiveMusicCtx.createBiquadFilter();
            noiseFilter.type = 'bandpass';
            noiseFilter.frequency.setValueAtTime(80, now);
            noiseFilter.frequency.linearRampToValueAtTime(200, now + 40);
            noiseFilter.frequency.linearRampToValueAtTime(60, now + 80);
            noiseFilter.Q.setValueAtTime(0.5, now);
            const noiseGain = archiveMusicCtx.createGain();
            noiseGain.gain.setValueAtTime(0.015, now);
            noiseSource.connect(noiseFilter);
            noiseFilter.connect(noiseGain);
            noiseGain.connect(archiveMusicCtx.destination);
            noiseSource.start(now);
            archiveMusicNodes.push(noiseSource, noiseFilter, noiseGain);
            archiveMusicPlaying = true;
        } catch(e) { console.log('Soundtrack lovecraftiana indisponivel:', e); }
    }

    function archiveStopMusic() {
        if (!archiveMusicPlaying) return;
        archiveMusicPlaying = false;
        archiveMusicNodes.forEach(node => {
            try { node.stop(); } catch(e) { try { node.disconnect(); } catch(e2) {} }
        });
        archiveMusicNodes = [];
        try { if (archiveMusicCtx) archiveMusicCtx.close(); } catch(e) {}
        archiveMusicCtx = null;
        const bgMusic = document.getElementById('bg-jazz-music');
        const cross = document.getElementById('music-cross-1');
        if (archiveMusicPrevState.enabled) {
            musicEnabled = true;
            if (cross) cross.classList.add('hidden');
            if (archiveMusicPrevState.track && archiveMusicPrevState.track !== 'defcon_ambience') {
                const sel = document.getElementById('music-selector');
                if (sel) sel.value = archiveMusicPrevState.track;
                currentTrackId = archiveMusicPrevState.track;
                changeTrack();
            } else if (archiveMusicPrevState.track === 'defcon_ambience') {
                startDefconAmbience();
            }
        } else {
            musicEnabled = false;
            if (cross) cross.classList.remove('hidden');
            if (bgMusic) bgMusic.pause();
        }
    }

    // Inicializacao: timer para verificar horario secreto
    setInterval(checkSecretTime, 30000);
    setTimeout(checkSecretTime, 1000);

</script>
</body>
</html>
